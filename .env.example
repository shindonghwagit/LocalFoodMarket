# docker-compose 환경변수 — 실제 값은 .env 에 넣고 git에 커밋하지 않기
# 사용법: cp .env.example .env 후 값 채우기

# Postgres (docker compose의 db 컨테이너용)
POSTGRES_DB=localfoodmarket
POSTGRES_USER=localfood
POSTGRES_PASSWORD=change-me-please

# Backend
JWT_SECRET=change-me-please-use-a-long-random-string
KAKAO_ADDRESS_API_KEY=your-kakao-rest-api-key

# 호스트 매핑 — /etc/hosts 또는 DNS에서 admin.localhost 가 127.0.0.1 을 가리키도록
APP_ORIGIN_USER=http://localhost
APP_ORIGIN_ADMIN=http://admin.localhost
